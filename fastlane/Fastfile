default_platform(:ios)

platform :ios do
  desc "Run tests"
  lane :test do
    run_tests(
      project: "UnitConverter.xcodeproj",
      scheme: "UnitConverter",
      device: "iPhone 16",
      clean: true,
      code_coverage: true
    )
  end

  desc "Build and push to TestFlight"
  lane :beta do
    setup_ci if ENV["CI"]

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true
    )

    sync_code_signing(
      type: "appstore",
      api_key: api_key,
      readonly: true
    )

    increment_build_number(
      build_number: ENV["GITHUB_RUN_NUMBER"] || "1",
      xcodeproj: "UnitConverter.xcodeproj"
    )

    build_app(
      project: "UnitConverter.xcodeproj",
      scheme: "UnitConverter",
      export_method: "app-store",
      output_directory: "build",
      output_name: "UnitConverter.ipa"
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Deploy to App Store"
  lane :release do
    setup_ci if ENV["CI"]

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true
    )

    sync_code_signing(
      type: "appstore",
      api_key: api_key,
      readonly: true
    )

    increment_build_number(
      build_number: ENV["GITHUB_RUN_NUMBER"] || "1",
      xcodeproj: "UnitConverter.xcodeproj"
    )

    build_app(
      project: "UnitConverter.xcodeproj",
      scheme: "UnitConverter",
      export_method: "app-store",
      output_directory: "build",
      output_name: "UnitConverter.ipa"
    )

    upload_to_app_store(
      api_key: api_key,
      skip_metadata: true,
      skip_screenshots: true,
      precheck_include_in_app_purchases: false,
      force: true
    )
  end
end
